# Vector Database
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your-qdrant-key

# Research APIs
SEMANTIC_SCHOLAR_API_KEY=your-ss-key
CROSSREF_EMAIL=your-email@example.com
